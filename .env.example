# Web Push (rider notification) — คัดลอกเป็น .env แล้วเติมค่าจริง
# สร้าง key คู่ด้วย: npm run push:keys
VITE_VAPID_PUBLIC_KEY=
VITE_RIDER_API_BASE_URL=/api/rider
VITE_APP_API_BASE_URL=/api/app
VITE_RIDER_CODE=D-02
VITE_ALLOW_LEGACY_RIDER_QUERY=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
