# ─────────────────────────────────────────────────────────────────────────────
# Capacitor (native iOS/Android) build env — โหลดโดย `vite build --mode capacitor`
# คัดลอกเป็น .env.capacitor (ถูก gitignore) แล้วเติมค่าจริง แล้วรัน `npm run cap:ios` / `cap:android`
#
# ต่างจาก web dev ตรงที่ native app ไม่มี vite proxy → ต้องชี้ไป backend ตรงๆ ด้วย absolute URL
# และต้องเป็น path จริงของ backend (proxy เคย rewrite /api/messenger → /v1/rider ให้)
# ─────────────────────────────────────────────────────────────────────────────

# absolute URL ของ backend (รวม path จริง)
# - iOS Simulator: ใช้ http://localhost:4000/... ได้เลย (แชร์ network กับ Mac) — ต้องมี ATS
#   NSAllowsLocalNetworking ใน ios/App/App/Info.plist (เพิ่มไว้แล้ว) เพราะเป็น http
# - Android emulator: ใช้ http://10.0.2.2:4000/... เพื่อชี้กลับมา backend บน Mac
# - เครื่องจริง: ใช้ LAN IP (เช่น http://192.168.x.x:4000) หรือ backend ที่ deploy (https)
VITE_MESSENGER_API_BASE_URL=http://localhost:4000/v1/rider
VITE_APP_API_BASE_URL=http://localhost:4000/v1/app

# public web origin สำหรับลิงก์/QR ที่ส่งให้ลูกค้า เช่น https://retail.example.com
# ถ้าไม่ตั้งค่า native build จะ fallback เป็น capacitor://localhost ซึ่งเปิดได้เฉพาะใน WebView
VITE_CUSTOMER_TRACKING_PUBLIC_ORIGIN=

# internal key สำหรับ build ทดสอบภายใน (เดิม vite proxy เป็นคนแนบให้)
# ⚠️ ค่านี้จะถูกฝังลง bundle ของแอป — สกัดออกได้ ห้ามใช้ค่า production จริงกับแอปที่แจกจ่ายภายนอก
VITE_INTERNAL_API_KEY=

# VAPID public key (เหมือน web) สำหรับ subscribe push บนเครื่องจริง
VITE_VAPID_PUBLIC_KEY=
VITE_MESSENGER_CODE=D-02

# 'true' = โชว์บัญชีตัวอย่าง + ปุ่มกรอกอัตโนมัติบนหน้า messenger login (สะดวกตอนเทสต์บน simulator)
# ปล่อยว่าง/ลบออกเมื่อ build release จริง เพื่อไม่ให้ demo login หลุดไปแอปจริง
VITE_SHOW_TEST_LOGIN=true

# หมายเหตุ backend (คนละ repo): ต้องเปิด CORS ให้ origin ของ Capacitor —
#   iOS: capacitor://localhost   |   Android: http://localhost / https://localhost
